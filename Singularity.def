# Portable Vina-GPU-2.1 image — builds from the CURRENT src/ (all fixes: dual co-docking,
# module refactor, cavity rescue + biased-init). Kernels compile per-machine at first run
# (make source + VINA_GPU_HOME), so the .sif runs on ANY NVIDIA GPU — give it to other PCs.
#
# Build (no docker needed):  singularity build --fakeroot autodock-vina-gpu-2.1.sif Singularity.def
#   (or: sudo singularity build autodock-vina-gpu-2.1.sif Singularity.def)
# Run:   singularity exec --nv autodock-vina-gpu-2.1.sif autodock-vina-gpu --help

Bootstrap: docker
From: nvidia/cuda:12.2.2-devel-ubuntu22.04

%files
    src/AutoDock-Vina-GPU-2.1/ /opt/vina-gpu/AutoDock-Vina-GPU-2.1/

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential gcc g++ wget tar ocl-icd-libopencl1 ocl-icd-opencl-dev clinfo
    rm -rf /var/lib/apt/lists/*

    # Boost 1.84.0 (program_options/filesystem/system/thread)
    cd /opt
    wget -q https://archives.boost.io/release/1.84.0/source/boost_1_84_0.tar.gz
    tar xzf boost_1_84_0.tar.gz && rm boost_1_84_0.tar.gz
    cd boost_1_84_0
    ./bootstrap.sh --with-libraries=program_options,filesystem,system,thread
    ./b2 -j$(nproc) install && ldconfig

    # Build Vina-GPU from source (kernels compile at runtime per-GPU)
    cd /opt/vina-gpu/AutoDock-Vina-GPU-2.1
    sed -i \
        -e 's|^WORK_DIR=.*|WORK_DIR=/opt/vina-gpu/AutoDock-Vina-GPU-2.1|' \
        -e 's|^BOOST_LIB_PATH=.*|BOOST_LIB_PATH=/opt/boost_1_84_0|' \
        -e 's|^OPENCL_LIB_PATH=.*|OPENCL_LIB_PATH=/usr/local/cuda|' \
        -e 's|^OPENCL_VERSION=.*|OPENCL_VERSION=-DOPENCL_3_0|' \
        -e 's|^GPU_PLATFORM=.*|GPU_PLATFORM=-DNVIDIA_PLATFORM|' \
        Makefile
    make clean && make source -j$(nproc)

    # wrapper + NVIDIA OpenCL ICD
    printf '#!/bin/bash\nulimit -s 8192\nOCL_CACHE="${HOME}/.cache/vina-gpu"\nmkdir -p "$OCL_CACHE"\nexport OPENCL_BINARY_PATH="${OPENCL_BINARY_PATH:-$OCL_CACHE}"\nexec /opt/vina-gpu/AutoDock-Vina-GPU-2.1/AutoDock-Vina-GPU-2-1 "$@"\n' > /usr/local/bin/autodock-vina-gpu
    chmod +x /usr/local/bin/autodock-vina-gpu
    mkdir -p /etc/OpenCL/vendors
    echo "libnvidia-opencl.so.1" > /etc/OpenCL/vendors/nvidia.icd

%environment
    export VINA_GPU_HOME=/opt/vina-gpu/AutoDock-Vina-GPU-2.1

%runscript
    exec autodock-vina-gpu "$@"
